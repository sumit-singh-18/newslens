# --- API KEYS ---
# Get yours at https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Missing Angle: Pro (primary) and Flash (fallback on 429/5xx). Override if your project uses different IDs.
# GEMINI_PRO_MODEL=gemini-2.5-pro
# GEMINI_FLASH_MODEL=gemini-2.5-flash

# --- DATABASE ---
# Default for development: sqlite:///./newslens.db
DATABASE_URL=sqlite:///./newslens.db

# --- SERVER CONFIG ---
PORT=8000
DEBUG=True

# --- NLP MODELS (OPTIONAL OVERRIDES) ---
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment
BIAS_MODEL_NAME=bucketresearch/politicalBiasBERT
    