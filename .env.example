# --- API KEYS ---
# Get yours at https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# GEMINI_API_KEY removed — replaced with data-driven coverage insights (no Gemini / external LLM for dashboard synthesis).

# --- DATABASE ---
# Default for development: sqlite:///./newslens.db
DATABASE_URL=sqlite:///./newslens.db

# --- SERVER CONFIG ---
PORT=8000
DEBUG=True

# --- NLP MODELS (OPTIONAL OVERRIDES) ---
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment
BIAS_MODEL_NAME=bucketresearch/politicalBiasBERT
    