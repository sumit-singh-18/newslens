{
  "name": "newslens-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild app.js --bundle --outfile=bundle.js --format=esm --loader:.js=jsx",
    "watch": "npm run build -- --watch",
    "serve": "python3 -m http.server 5173 --bind 127.0.0.1",
    "dev": "npm run build && npm run serve"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.7",
    "html2canvas": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
